# Frontend environment variables.
#
# Variables prefixed with VITE_ are inlined into the frontend bundle
# at build time. This file is committed as documentation — it lists
# every env var the app reads, with its default value.
#
# For local overrides, copy this file to `.env` (which is gitignored)
# and edit freely. Unset variables fall back to the defaults shown here.

# ─── Backend URLs ────────────────────────────────────────────────────────────

# REST API for the Ebisu backend (cards, reviews, forests, documents,
# and static resources at /resources/{name}).
VITE_API_BASE_URL=http://localhost:8764

# WebSocket URL for the KataGo analysis middleware. This is the
# out-of-the-box default for fresh installs only — at runtime the user's
# profile setting `settings.katago.url` takes precedence when set. See
# services/analysis-service.ts::connect() for the resolution order.
VITE_KATAGO_WS_URL=ws://127.0.0.1:41948
